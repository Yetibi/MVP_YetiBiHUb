      "parameters": {
        "jsCode": "// Pegar esto en un nodo \"Code\" (JavaScript) reemplazando \"Formatear mensaje\"\n\nconst body = $input.item.json.body || {};\n\nconst archivos = Array.isArray(body.archivos) && body.archivos.length > 0\n  ? body.archivos.join(', ')\n  : 'N/A';\n\nconst mensajeTexto = `🐺 Nuevo intake — Yeti BI\n\n👤 Perfil: ${body.perfil || 'N/A'}\n🏢 Sector: ${body.sector || 'N/A'}\n🎯 Alcance del diagnóstico: ${body.alcance || 'N/A'}\n📧 Correo: ${body.correo || 'N/A'}\n\n😣 Fuga declarada: ${body.dolor_declarado || 'N/A'}\n\n🚀 To-Be (objetivo): ${body.to_be_objetivo || 'N/A'}\n📊 Nivel de madurez analítica buscado: ${body.to_be_nivel ?? 'N/A'}\n\n🛠️ Tecnología visible: ${body.tecnologia_visible || 'N/A'}\n📈 Métrica que ya maneja: ${body.metrica_declarada || 'N/A'}\n\n📎 Documentos adjuntos: ${body.fileCount ?? 0}\n📄 Archivos: ${archivos}`;\n\nreturn [\n  {\n    json: {\n      mensajeTexto\n    }\n  }\n];\n"
      },
